APP_NAME=LawBridge Backend
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Defaults point to the model folders shipped inside this backend project.
# Relative paths are resolved from the backend project root.
SENTIMENT_MODEL_PATH=models/sentiment_berturk_model
INTENT_MODEL_PATH=models/intent_berturk_model
LEGAL_MODEL_PATH=models/lawbridge_legal_model
REASONING_MODEL_PATH=models/MiniLM_weak_summary_to_reasoning_seed42_ep7_msl256
JUDGEMENTS_DATASET_DIR=Structured_Judgements

MODEL_DEVICE=auto
EAGER_LOAD_MODELS=false
MAX_SEQUENCE_LENGTH=512
ANALYSIS_STORE_PATH=data/analyses.json
