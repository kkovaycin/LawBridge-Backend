APP_NAME=LawBridge Backend
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Real tokens must stay in .env. Do not commit .env.
HF_TOKEN=
SENTIMENT_MODEL_PATH=lawbridge/sentiment-berturk
INTENT_MODEL_PATH=lawbridge/intent-berturk
LEGAL_MODEL_PATH=lawbridge/lawbridge-legal-model
RETRIEVAL_MODEL_PATH=lawbridge/turkish-legal-precedent-retrieval

JUDGEMENTS_DATASET_DIR=Structured_Judgements
MODEL_DEVICE=auto
EAGER_LOAD_MODELS=false
MAX_SEQUENCE_LENGTH=512

YOUTUBE_API_KEY=
YOUTUBE_MAX_COMMENTS=25
YOUTUBE_REQUEST_TIMEOUT_SECONDS=15
ANALYSIS_STORE_PATH=data/analyses.json
